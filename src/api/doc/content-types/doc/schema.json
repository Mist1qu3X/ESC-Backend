{
  "kind": "collectionType",
  "collectionName": "docs",
  "info": {
    "singularName": "doc",
    "pluralName": "docs",
    "displayName": "Document",
    "description": "Documents library"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "theme": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Official Documents",
        "Rules",
        "Assemblies",
        "Sustainability",
        "Newsletters",
        "Courses",
        "PRESS RELEASES",
        "RELEASES"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "All Documents",
        "Official Documents",
        "Rules",
        "Assemblies",
        "Sustainability",
        "Newsletters",
        "Courses"
      ]
    },
    "version": {
      "type": "string",
      "default": "v1.0"
    },
    "description": {
      "type": "text"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "file": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "files"
      ]
    },
    "fileSize": {
      "type": "string",
      "default": "1.0 MB"
    },
    "downloadCount": {
      "type": "integer",
      "default": 0
    }
  }
}
