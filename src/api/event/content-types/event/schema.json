{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event",
    "description": "Competitions and events calendar"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["championship", "education", "workshop"],
      "required": true,
      "default": "championship"
    },
    "statusEvent": {
      "type": "enumeration",
      "enum": ["UPCOMING", "FINISHED"],
      "required": true,
      "default": "UPCOMING"
    },
    "category": {
      "type": "string",
      "default": "SENIOR"
    },
    "month": {
      "type": "string"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "venue": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "athletes": {
      "type": "string",
      "default": "480+"
    },
    "nations": {
      "type": "string",
      "default": "38"
    },
    "disciplines": {
      "type": "text"
    },
    "contactEmail": {
      "type": "email",
      "default": "technical@esc-shooting.eu"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "venueImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}